# RAG System Configuration

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Logging
LOG_LEVEL=INFO

# Document Processing
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# Embeddings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
BATCH_SIZE=32

# Retrieval
N_RETRIEVE=10
RETRIEVAL_TYPE=hybrid
BM25_K1=1.5
BM25_B=0.75

# Reranking
RERANKER_MODEL=cross-encoder/mmarco-MiniLMv2-L12-H384-v1
N_RERANK=5
RERANK_THRESHOLD=0.5

# LLM Configuration
LLM_MODEL=HuggingFaceTB/SmolLM2-1.7B-Instruct
LLM_DEVICE=mps
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=512
LLM_TOP_P=0.95

# Vector Database
CHROMA_COLLECTION_NAME=rag_documents
CHROMA_DISTANCE_METRIC=cosine

# MLFlow
MLFLOW_EXPERIMENT_NAME=RAG_Experiments
MLFLOW_RUN_NAME=default_run
